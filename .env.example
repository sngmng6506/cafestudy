NODE_ENV=
PORT=
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Object storage (Cloudflare R2 / AWS S3-compatible)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
AWS_ENDPOINT_URL=
AWS_S3_BUCKET_NAME=

# Naver Search API
NAVER_SEARCH_CLIENT_ID=
NAVER_SEARCH_CLIENT_SECRET=

# Somoim 멤버 동기화 (수동 POST /api/members/sync 용)
INTERNAL_API_KEY=change-me-to-a-secret-value
SYNC_ENDPOINT=http://localhost:3000/api/members/sync

# 자동 크롤링 설정
# SOMOIM_URL을 설정하면 서버 시작 시 자동 크롤링이 활성화됩니다
SOMOIM_URL=
# cron 표현식 (기본: 매일 새벽 2시 KST). Asia/Seoul 기준
CRAWL_SCHEDULE=0 2 * * *
# Docker/Railway 환경에서 시스템 Chromium 경로 (Alpine: /usr/bin/chromium-browser)
# 로컬 개발 시 비워두면 Puppeteer 내장 Chrome 사용
PUPPETEER_EXECUTABLE_PATH=
# Docker 빌드 시 Puppeteer 내장 Chrome 다운로드 생략 여부
PUPPETEER_SKIP_DOWNLOAD=
